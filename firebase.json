{
  "hosting": {
    "public": "public-data",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "dataset.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      }
    ]
  }
}
