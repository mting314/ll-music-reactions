# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# Daily-refreshed dataset object in GCS (public, CDN-cached). When set, the app
# fetches it at runtime; when unset, it uses the bundled src/data snapshot.
# Enable after provisioning the pipeline (see pipeline/setup-gcp.sh):
# VITE_DATA_URL=https://storage.googleapis.com/<bucket>/dataset.json
