# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# Firestore-backed data API (Cloud Run), refreshed daily. The app fetches the
# dataset from here at runtime; there is no bundled fallback, so this must be set
# (an unreachable API shows an error rather than stale data).
VITE_DATA_API=https://ll-data-api-278890546984.us-central1.run.app
