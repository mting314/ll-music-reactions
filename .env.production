# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# URL the app fetches the dataset JSON from at runtime. Today this is the Cloud
# Run data API's /data endpoint; the planned cutover points it at a static file
# on Firebase Hosting (…/dataset.json) — both return the same shape. There is no
# bundled fallback, so this must be set (an unreachable URL shows an error, not
# stale data).
VITE_DATA_URL=https://ll-data-api-278890546984.us-central1.run.app/data
