# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# DB-backed data API (Cloud Run + Cloud SQL). When set, the app fetches the
# dataset at runtime; when unset, it uses the bundled src/data snapshot.
# Enable after provisioning the pipeline (see pipeline/setup-gcp.sh):
# VITE_DATA_API=https://ll-data-api-XXXXXXXX.us-central1.run.app
