# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# Base URL of the data CDN — the ll-music-data repo served via GitHub Pages. The
# app fetches per-entity JSON files (songs.json, artists.json, …) under this base
# at runtime. There is no bundled fallback, so this must be set (an unreachable
# base shows an error, not stale data).
VITE_DATA_BASE=https://mting314.github.io/ll-music-data
