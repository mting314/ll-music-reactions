# Cloud Run export service (ffmpeg). Used by production builds.
VITE_EXPORT_API=https://ll-export-278890546984.us-central1.run.app

# Firestore-backed data API (Cloud Run), refreshed daily. When set, the app
# fetches the dataset at runtime; when unset, it uses the bundled src/data
# snapshot (which remains the fallback if the API is unreachable).
VITE_DATA_API=https://ll-data-api-278890546984.us-central1.run.app
